{
  "version": 1,
  "hooks": {
    "userPromptSubmit": [
      {
        "type": "command",
        "bash": "bash hooks/scripts/inject-crispy-protocol.sh",
        "powershell": "pwsh -NoProfile -File hooks/scripts/inject-crispy-protocol.ps1",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "bash hooks/scripts/pre-branch-check.sh",
        "powershell": "pwsh -NoProfile -File hooks/scripts/pre-branch-check.ps1",
        "timeoutSec": 10
      },
      {
        "type": "command",
        "bash": "bash hooks/scripts/pre-branch-fetch.sh",
        "powershell": "pwsh -NoProfile -File hooks/scripts/pre-branch-fetch.ps1",
        "timeoutSec": 30
      }
    ]
  }
}
