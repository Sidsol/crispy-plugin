{
  "version": 1,
  "hooks": {
    "userPromptSubmit": [
      {
        "type": "command",
        "bash": "bash hooks/scripts/inject-crispy-protocol.sh",
        "powershell": "pwsh -NoProfile -File hooks/scripts/inject-crispy-protocol.ps1",
        "timeoutSec": 5
      }
    ],
    "preToolUse": [
      {
        "type": "command",
        "bash": "bash hooks/scripts/crispy-metrics-start.sh",
        "powershell": "pwsh -NoProfile -File hooks/scripts/crispy-metrics-start.ps1",
        "timeoutSec": 5
      }
    ],
    "postToolUse": [
      {
        "type": "command",
        "bash": "bash hooks/scripts/crispy-metrics-record.sh",
        "powershell": "pwsh -NoProfile -File hooks/scripts/crispy-metrics-record.ps1",
        "timeoutSec": 10
      }
    ]
  }
}
